# AI Agents Starter Kit – Environment Variables
# Copy this file to .env and fill in with your real keys.
# NEVER commit the .env file to the repository!

# ── Anthropic (Claude Code) ───────────────────────────────────────────────────
CLAUDE_API_KEY=

# ── OpenAI (Codex CLI) ───────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google (Gemini CLI) ──────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── GitHub (Copilot CLI) ─────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Optional Settings ────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info

# Default timeout for API calls (in seconds)
API_TIMEOUT=60

# Enable persistent memory (local MCP)
ENABLE_MEMORY=true
MEMORY_FILE=./memory_log.json
