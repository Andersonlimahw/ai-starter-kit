# AI Agents Starter Kit – Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves reais.
# NUNCA commite o arquivo .env no repositório!

# ── Anthropic (Claude Code) ───────────────────────────────────────────────────
CLAUDE_API_KEY=

# ── OpenAI (Codex CLI) ───────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google (Gemini CLI) ──────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── GitHub (Copilot CLI) ─────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Configurações opcionais ──────────────────────────────────────────────────
# Nível de log: debug | info | warn | error
LOG_LEVEL=info

# Timeout padrão para chamadas de API (em segundos)
API_TIMEOUT=60

# Habilitar memória persistente (MCP local)
ENABLE_MEMORY=true
MEMORY_FILE=./memory_log.json
